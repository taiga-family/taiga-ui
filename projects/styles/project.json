{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "styles",
    "implicitDependencies": ["!testing"],
    "prefix": "tui",
    "projectType": "library",
    "sourceRoot": "projects/{projectName}",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "cd {projectRoot} && npx cpy ./* '!project.json' '../../dist/{projectName}'"
            },
            "outputs": ["{workspaceRoot}/dist/{projectName}"]
        },
        "publish": {
            "dependsOn": [
                {
                    "dependencies": false,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "commands": ["cp ./LICENSE ./dist/{projectName}", "ts-node ./scripts/publish.ts --path ./dist/{projectName} --dry-run {args.dry-run} --customVersion {args.customVersion} --customTag {args.customTag}"],
                "forwardAllArgs": false,
                "parallel": false
            }
        }
    }
}
