exports[`ng-update chip and badge selectors migrates deprecated appearances for tui-badge: test.html 1`] = `
{
  "0. Before": "
                <tui-badge appearance="error" size="s"><span>1</span></tui-badge>
                <tui-badge appearance="success" />
