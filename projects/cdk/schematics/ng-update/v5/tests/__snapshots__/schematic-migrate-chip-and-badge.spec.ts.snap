exports[`ng-update chip and badge selectors migrates deprecated appearances for tui-badge: test.html 1`] = `
{
  "0. Before": "
                <tui-badge
                    appearance="error"
                    size="s"
                >
                    <span>1</span>
                </tui-badge>
                <tui-badge appearance="success" />
                <tui-badge [appearance]="'error'"></tui-badge>
                <tui-badge [appearance]="computedAppearance">123</tui-badge>
                <button
                    tuiIconButton
                    [appearance]="'icon'"
                ></button>
            ",
  "1. After": "
                <span tuiBadge
                    appearance="negative"
                    size="s"
                >
                    <span>1</span>
                </span>
                <span tuiBadge appearance="positive" ></span>
                <span tuiBadge [appearance]="'negative'"></span>
                <!-- TODO: (Taiga UI migration) [appearance] binding uses a dynamic expression. If it can produce "error"/"success"/"glass", replace with "negative"/"positive"/"secondary-grayscale" -->
<span tuiBadge [appearance]="computedAppearance">123</span>
                <button
                    tuiIconButton
                    [appearance]="'icon'"
                ></button>
            ",
}
`;

