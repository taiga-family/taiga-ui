exports[`ng-update FilterByInput migration does not duplicate filterWith wrapper when migration runs again (idempotent): test.ts 1`] = `
{
  "0. Before": "
                import { TuiFilterByInputPipe, TuiFilterByInputOptions } from '@taiga-ui/core';

                @Component({
                    template: \`<tui-data-list-wrapper [items]="items | tuiFilterByInput: filterWithMatcher" />\`,
                })
                export class Example {
                    items = ['a', 'b'];

                    matcher = (item: string, query: string) => item.includes(query);

                    filterWithMatcher: TuiFilterByInputOptions['filter'] = (items, query, stringify) => items.filter((item) => this.matcher(item, query, stringify));
                }
            ",
  "1. After": "
                import { TuiFilterByInputPipe, TuiFilterByInputOptions } from '@taiga-ui/core';

                @Component({
                    template: \`<tui-data-list-wrapper [items]="items | tuiFilterByInput: filterWithFilterWithMatcher" />\`,
                })
                export class Example {
                    items = ['a', 'b'];

                    matcher = (item: string, query: string) => item.includes(query);

                    filterWithMatcher: TuiFilterByInputOptions['filter'] = (items, query, stringify) => items.filter((item) => this.matcher(item, query, stringify));
                
    filterWithFilterWithMatcher: TuiFilterByInputOptions['filter'] = (items, query, stringify) => items.filter((item) => this.filterWithMatcher(item, query, stringify));
}
            ",
}
`;

