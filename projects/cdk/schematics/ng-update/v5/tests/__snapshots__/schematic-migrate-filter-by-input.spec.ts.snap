                    template: \`<tui-data-list-wrapper [items]="items | tuiFilterByInput: filterWithDefaultMatcher" />\`,
                })
                export class Example {
                    items = ['a', 'b'];

                    defaultMatcher = TUI_DEFAULT_MATCHER;
                
    filterWithDefaultMatcher: TuiFilterByInputOptions['filter'] = (items, query, stringify) => items.filter((item) => this.defaultMatcher(item, query, stringify));
}
            ",
}
`;
