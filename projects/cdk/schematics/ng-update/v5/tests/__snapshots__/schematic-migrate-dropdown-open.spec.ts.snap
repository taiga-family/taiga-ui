exports[`ng-update tuiDropdownOpen to tuiDropdownAuto reuses an existing inject import without duplicating it: test.ts 1`] = `
{
  "0. Before": "
                import {inject} from '@angular/core';
                import {TuiDropdownDirective, tuiDropdownOpen} from '@taiga-ui/core';

                export class Test {
                    private readonly directive = inject(TuiDropdownDirective);
                    protected readonly open = tuiDropdownOpen();
                }
            ",
  "1. After": "
                import {inject} from '@angular/core';
                import { TuiDropdownDirective, TuiDropdownOpen } from '@taiga-ui/core';

                export class Test {
                    private readonly directive = inject(TuiDropdownDirective);
                    protected readonly open = inject(TuiDropdownOpen).open;
                }
            ",
}
`;

