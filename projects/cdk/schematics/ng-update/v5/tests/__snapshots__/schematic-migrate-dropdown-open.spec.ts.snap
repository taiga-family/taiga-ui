exports[`ng-update tuiDropdownOpen to tuiDropdownAuto keeps chained calls like tuiDropdownOpen().set(true): test.ts 1`] = `
{
  "0. Before": "
                import {tuiDropdownOpen} from '@taiga-ui/core';

                export class Test {
                    protected readonly open = tuiDropdownOpen();

                    public toggle(): void {
                        this.open.set(true);
                    }
                }
            ",
  "1. After": "import { inject } from "@angular/core";

                import { TuiDropdownOpen } from '@taiga-ui/core';

                export class Test {
                    protected readonly open = inject(TuiDropdownOpen).open;

                    public toggle(): void {
                        this.open.set(true);
                    }
                }
            ",
}
`;

