}
`;

exports[`ng-update renames [defaultActiveYearMonth] to [month] on <tui-calendar> and keeps [disabledItemHandler] on <tui-textfield>: test.html 1`] = `
{
  "0. Before": "
                <tui-input-date-time
                    formControlName="date"
                    [defaultActiveYearMonth]="initialMonth"
                    [disabledItemHandler]="disabledHandler"
                >
                    Date
                </tui-input-date-time>
            ",
  "1. After": "
                <tui-textfield
                    
                    
                    [disabledItemHandler]="disabledHandler"
                >
