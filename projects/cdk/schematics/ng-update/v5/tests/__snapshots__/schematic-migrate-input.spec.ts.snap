}
`;

exports[`ng-update legacy input reuses inner <input tuiTextfieldLegacy> and preserves its attrs: test.html 1`] = `
{
  "0. Before": "
                <tui-input formControlName="value">
                    Email
                    <input
                        autocomplete="email"
                        placeholder="[Email]"
                        tuiTextfieldLegacy
                        type="email"
                    />
                </tui-input>
            ",
  "1. After": "
                <tui-textfield>
                <input
                        autocomplete="email"
                        placeholder="[Email]"
                        tuiInput
                        type="email" formControlName="value"/>
                </tui-textfield>
            ",
}
`;

exports[`ng-update legacy input routes dropdown attrs to wrapper and adds TODO for prefix/postfix: test.html 1`] = `
{
  "0. Before": "
                <tui-input
                    formControlName="value"
                    tuiDropdownDirection="top"
                    tuiTextfieldPostfix="USD"
                    tuiTextfieldPrefix="$"
                    [tuiDropdownLimitWidth]="'fixed'"
                >
                    Amount
                </tui-input>
            ",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tui-input migration (see https://taiga-ui.dev/components/input):
     - tuiTextfieldPostfix, tuiTextfieldPrefix has no direct equivalent in v5. Implement using custom content inside <tui-textfield>.
-->
                <tui-textfield tuiDropdownDirection="top" tuiTextfieldPostfix="USD" tuiTextfieldPrefix="$" [tuiDropdownLimitWidth]="'fixed'">
                <label tuiLabel>Amount</label>
                <input tuiInput formControlName="value" />
                </tui-textfield>
            ",
}
`;
