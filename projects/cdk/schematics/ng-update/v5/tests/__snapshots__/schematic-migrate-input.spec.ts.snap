exports[`ng-update legacy input adds TODO for dynamic [tuiTextfieldLabelOutside] without wrapping: test.html 1`] = `
{
  "0. Before": "<tui-input formControlName="value" [tuiTextfieldLabelOutside]="isOutside">Label</tui-input>",
  "1. After": "<!-- TODO: (Taiga UI migration) tui-input migration (see https://taiga-ui.dev/components/input):
     - [tuiTextfieldLabelOutside]="isOutside" is dynamic and cannot be migrated automatically. Use <label tuiLabel> inside <tui-textfield> for floating label or outside for static label.
-->
<tui-textfield>
Label
<input tuiInput formControlName="value" />
</tui-textfield>",
}
`;

exports[`ng-update legacy input converts [tuiTextfieldCustomContent] binding to <tui-icon *polymorpheusOutlet> and renames tuiTextfieldFiller to filler: test.html 1`] = `
{
  "0. Before": "<tui-input formControlName="value" [tuiTextfieldCustomContent]="myTpl" [tuiTextfieldFiller]="hint">Label</tui-input>",
  "1. After": "<tui-textfield [filler]="hint">
<label tuiLabel>Label</label>
<input tuiInput formControlName="value" />

<tui-icon
    *polymorpheusOutlet="myTpl as src"
    [icon]="src"
/>
</tui-textfield>",
}
`;

exports[`ng-update legacy input converts [tuiTextfieldCustomContent] binding to <tui-icon *polymorpheusOutlet> and renames tuiTextfieldFiller to filler: test.ts 1`] = `
{
  "0. Before": "
                import {TuiInputModule} from '@taiga-ui/legacy';

                @Component({
                  standalone: true,
                  imports: [TuiInputModule],
                  templateUrl: './test.html',
                })
                export class TestComponent {}
            ",
  "1. After": "import { PolymorpheusOutlet } from "@taiga-ui/polymorpheus";
