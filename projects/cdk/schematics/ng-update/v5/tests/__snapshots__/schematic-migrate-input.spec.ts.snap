exports[`ng-update legacy input migrates multiple tui-input elements in one template: test.html 1`] = `
{
  "0. Before": "
                <tui-input formControlName="a">First</tui-input>
                <tui-input formControlName="b">Second</tui-input>
            ",
  "1. After": "
                <tui-textfield>
                <label tuiLabel>First</label>
                <input tuiInput formControlName="a" />
                </tui-textfield>
                <tui-textfield>
                <label tuiLabel>Second</label>
                <input tuiInput formControlName="b" />
                </tui-textfield>
            ",
}
`;

exports[`ng-update legacy input migrates tui-input wrapper attrs and routes them correctly: test.html 1`] = `
{
  "0. Before": "
                <tui-input
                    formControlName="value"
                    tuiHintContent="Hint"
                    tuiTextfieldSize="s"
                    [tuiTextfieldCleaner]="true"
                >
                    Email
                </tui-input>
            ",
  "1. After": "
                <tui-textfield tuiTextfieldSize="s" [tuiTextfieldCleaner]="true">
                <label tuiLabel>Email</label>
                <input tuiInput formControlName="value" />
<tui-icon tuiTooltip="Hint" />
                </tui-textfield>
            ",
}
`;

