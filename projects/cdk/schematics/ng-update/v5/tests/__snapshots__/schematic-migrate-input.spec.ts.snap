exports[`ng-update legacy input keeps tuiTextfieldCustomContent migration working alongside hint content: test.html 1`] = `
{
  "0. Before": "
                <tui-input
                    formControlName="value"
                    tuiHintContent="Hint"
                    [tuiTextfieldCustomContent]="myTpl"
                >
                    Label
                </tui-input>
            ",
  "1. After": "
                <tui-textfield>
                <label tuiLabel>Label</label>
                <input tuiInput formControlName="value" />
<tui-icon tuiTooltip="Hint" />

                <tui-icon
                    *polymorpheusOutlet="myTpl as src"
                    [icon]="src"
                />
                </tui-textfield>
            ",
}
`;

