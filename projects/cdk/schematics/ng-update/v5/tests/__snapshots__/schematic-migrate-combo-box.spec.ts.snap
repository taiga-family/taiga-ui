exports[`ng-update ComboBox migrates *tuiDataList to *tuiDropdown: test.html 1`] = `
{
  "0. Before": "
                <tui-combo-box [formControl]="control">
                    Label
                    <tui-data-list *tuiDataList>
                        <button
                            tuiOption
                            [value]="item"
                        >
                            {{ item }}
                        </button>
                    </tui-data-list>
                </tui-combo-box>
            ",
  "1. After": "
                <tui-textfield>
<label tuiLabel>
                    Label
                    </label>

<input tuiComboBox [formControl]="control" />
<tui-data-list *tuiDropdown>
                        <button
                            tuiOption
                            [value]="item"
                        >
                            {{ item }}
                        </button>
                    </tui-data-list>
                </tui-textfield>
            ",
}
`;

