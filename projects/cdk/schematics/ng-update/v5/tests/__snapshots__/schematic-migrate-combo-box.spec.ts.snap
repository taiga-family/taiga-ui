                  standalone: true,
                  imports: [TuiComboBox],
                  templateUrl: './test.html',
                })
                export class TestComponent {}
            ",
}
`;

exports[`ng-update ComboBox migrates combo-box with all properties combined: test.html 1`] = `
{
  "0. Before": "
                <tui-combo-box
                    [formControl]="control"
                    [search]="search"
                    [strict]="false"
                    [strictMatcher]="myMatcher"
                    [valueContent]="contentTpl"
                    (searchChange)="search = $event"
                >
                    Choose a hero
                    <input
                        placeholder="Start typing..."
                        tuiTextfieldLegacy
                    />
                    <tui-data-list-wrapper
                        *tuiDataList
                        [itemContent]="contentTpl"
                        [items]="heroes"
                    />
                </tui-combo-box>
            ",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tui-combo-box migration (see https://taiga-ui.dev/components/combo-box):
     - [search] / (searchChange): use native (input) event on <input tuiComboBox>
-->
<tui-textfield #textfieldRef [content]="textfieldRef.focused() ? '' : contentTpl"
                >
<label tuiLabel>
                    Choose a hero
                    </label>
<input tuiComboBox [formControl]="control" [strict]="false" [matcher]="myMatcher" (input)="search = $event.target.value"
                        placeholder="Start typing..."
                    />
                    <tui-data-list-wrapper
                        *tuiDropdown
                        [itemContent]="contentTpl"
                        [items]="heroes"
                    />
                </tui-textfield>
            ",
}
`;

