// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`ng-update ComboBox [stringify] / [identityMatcher] / [disabledItemHandler]: test.html 1`] = `
{
  "0. Before": "
                <tui-combo-box
                    [disabledItemHandler]="disabledFn"
                    [formControl]="control"
                    [identityMatcher]="matcherFn"
                    [stringify]="stringifyFn"
                >
                    Label
                </tui-combo-box>
            ",
  "1. After": "
                <tui-textfield
                    [disabledItemHandler]="disabledFn"
                    [identityMatcher]="matcherFn"
                    [stringify]="stringifyFn"
                >
<label tuiLabel>
                    Label
                </label>

<input tuiComboBox [formControl]="control" />
</tui-textfield>
            ",
}
`;

exports[`ng-update ComboBox [valueContent] => tui-textfield[content]: test.html 1`] = `
{
  "0. Before": "
                <tui-combo-box
                    [formControl]="control"
                    [valueContent]="myContent"
                >
                    Label
                </tui-combo-box>
            ",
  "1. After": "
                <tui-textfield #textfieldRef [content]="textfieldRef.focused() ? '' : myContent"
                >
<label tuiLabel>
                    Label
                </label>

<input tuiComboBox [formControl]="control" />
</tui-textfield>
            ",
}
`;

exports[`ng-update ComboBox adds TODO for [search] and (searchChange): test.html 1`] = `
{
  "0. Before": "
                <tui-combo-box
                    [formControl]="control"
                    [search]="searchValue"
                    (searchChange)="onSearch($event)"
                >
                    Label
                </tui-combo-box>
            ",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tui-combo-box migration (see https://taiga-ui.dev/components/combo-box):
     - [search] / (searchChange): use native (input) event on <input tuiComboBox>
-->
<tui-textfield
                >
<label tuiLabel>
                    Label
                </label>

<input tuiComboBox [formControl]="control" (input)="onSearch($event.target.value)" />
</tui-textfield>
            ",
}
`;

exports[`ng-update ComboBox handles multiple combo-boxes in the same template: test.html 1`] = `
{
  "0. Before": "
                <tui-combo-box [formControl]="first">First</tui-combo-box>

                <tui-combo-box [(ngModel)]="second">
                    Second
                    <tui-data-list-wrapper
                        *tuiDataList
                        [items]="items"
                    />
                </tui-combo-box>
            ",
  "1. After": "
                <tui-textfield>
<label tuiLabel>First</label>

<input tuiComboBox [formControl]="first" />
</tui-textfield>

                <tui-textfield>
<label tuiLabel>
                    Second
                    </label>

<input tuiComboBox [(ngModel)]="second" />
<tui-data-list-wrapper
                        *tuiDropdown
                        [items]="items"
                    />
                </tui-textfield>
            ",
}
`;

