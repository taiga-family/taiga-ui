exports[`ng-update ComboBox migrates TuiComboBoxModule import and basic tui-combo-box template: test.ts 1`] = `
{
  "0. Before": "
                import {TuiComboBoxModule} from '@taiga-ui/legacy';

                @Component({
                  standalone: true,
                  imports: [TuiComboBoxModule],
                  templateUrl: './test.html',
                })
                export class TestComponent {}
            ",
  "1. After": "import { TuiComboBox } from "@taiga-ui/kit";

