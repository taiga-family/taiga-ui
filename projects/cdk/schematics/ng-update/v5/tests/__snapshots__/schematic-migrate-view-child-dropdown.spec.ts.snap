            ",
  "1. After": "import { TuiDropdownContent } from "@taiga-ui/core";

                import {forwardRef, TemplateRef, ViewChild} from '@angular/core';

                export class MyComponent {
// TODO: (Taiga UI migration) Replace @ViewChild setter with viewChild() + effect(() => this.<signal>.set(this.<name>())). See https://taiga-ui.dev/components/textfield
                    @ViewChild(forwardRef(() => TuiDropdownContent), {
                        read: TemplateRef,
                    })
                    protected set template(value: any) {
                        this.dropdown.set(value);
                        this.other = value;
                    }
                }
            ",
}
`;
