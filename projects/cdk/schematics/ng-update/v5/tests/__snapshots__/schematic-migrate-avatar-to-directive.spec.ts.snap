// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`ng-update avatar adds tuiAvatar attribute when element wraps img: test.html 1`] = `
{
  "0. Before": "<tui-avatar><img [src]="avatarUrl" alt="User" /></tui-avatar>",
  "1. After": "<span tuiAvatar><img [src]="avatarUrl" alt="User" /></span>",
}
`;

exports[`ng-update avatar complex templates: test.html 1`] = `
{
  "0. Before": "
                <section *ngFor="let size of sizes">
                    <tui-avatar [size]="size">{{ size | uppercase }}</tui-avatar>
                    <tui-avatar
                        src="@tui.user"
                        [size]="size"
                    />
                </section>
            ",
  "1. After": "
                <section *ngFor="let size of sizes">
                    <span tuiAvatar [size]="size">{{ size | uppercase }}</span>
                    <span tuiAvatar="@tui.user"
                       
                        [size]="size"
                    ></span>
                </section>
            ",
}
`;

exports[`ng-update avatar moves src value to tuiAvatar attribute on host element: test.html 1`] = `
{
  "0. Before": "<a tuiAvatar src="avatar.png"></a>",
  "1. After": "<a tuiAvatar="avatar.png"></a>",
}
`;

exports[`ng-update avatar picture inside tui-avatar: test.html 1`] = `
{
  "0. Before": "
                <tui-avatar class="tui-space_horizontal-4">
                    <picture>
                        <source
                            media="(min-width: 600px)"
                            srcset="/assets/images/angular.svg"
                        />
                        <img
                            alt="Alex Inkin"
                            src="/assets/images/avatar.jpg"
                        />
                    </picture>
                </tui-avatar>
            ",
  "1. After": "
                <span tuiAvatar class="tui-space_horizontal-4">
                    <picture>
                        <source
                            media="(min-width: 600px)"
                            srcset="/assets/images/angular.svg"
                        />
                        <img
                            alt="Alex Inkin"
                            src="/assets/images/avatar.jpg"
                        />
                    </picture>
                </span>
            ",
}
`;

