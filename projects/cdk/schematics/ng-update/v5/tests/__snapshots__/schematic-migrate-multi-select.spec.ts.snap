exports[`ng-update legacy multi-select migrates full-featured tui-multi-select: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select
                    [stringify]="stringify"
                    [identityMatcher]="matcher"
                    [rows]="3"
                    [valueContent]="tmpl"
                    placeholder="Pick items"
                    [editable]="false"
                    [tagValidator]="isValid"
                    [autoColor]="true"
                    tuiTextfieldLabelOutside
                    formControlName="items"
                >
                    <label tuiLabel>Select</label>
                    <tui-data-list-wrapper *tuiDataList [items]="items" />
                </tui-multi-select>",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tuiTextfieldLabelOutside was removed. In v5, wrap <tui-textfield> in <label tuiLabel> for label-outside pattern. See: https://taiga-ui.dev/components/label -->
                <!-- TODO: (Taiga UI migration) [autoColor] was removed. Use tuiChip with auto-color appearance instead. See https://taiga-ui.dev/components/chip#auto-color -->
                <tui-textfield multi tuiChevron
                    [stringify]="stringify"
                    [identityMatcher]="matcher"
                    [rows]="3"
                    [content]="tmpl"
                >
                    <input tuiInputChip tuiSelectLike placeholder="Pick items" formControlName="items" />
<tui-input-chip *tuiItem="let ctx" [appearance]="isValid(ctx.item) ? '' : 'negative'" />
<label tuiLabel>Select</label>
                    <tui-data-list-wrapper *tuiDropdown [items]="items" />
                </tui-textfield>",
}
`;

exports[`ng-update legacy multi-select migrates multiple tui-multi-select elements in one template: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select formControlName="first">
                    <tui-data-list-wrapper *tuiDataList [items]="items" />
                </tui-multi-select>
                <tui-multi-select formControlName="second">
                    <tui-data-list-wrapper *tuiDataList [items]="items" />
                </tui-multi-select>",
  "1. After": "
                <tui-textfield multi tuiChevron>
                    <input tuiInputChip formControlName="first" />
<tui-data-list-wrapper *tuiDropdown [items]="items" />
                </tui-textfield>
                <tui-textfield multi tuiChevron>
                    <input tuiInputChip formControlName="second" />
<tui-data-list-wrapper *tuiDropdown [items]="items" />
                </tui-textfield>",
}
`;

