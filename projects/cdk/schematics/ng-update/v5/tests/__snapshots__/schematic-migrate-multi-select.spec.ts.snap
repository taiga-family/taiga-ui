// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`ng-update legacy multi-select adds [readOnly] to <input> when [editable] is a dynamic expression: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select [editable]="isEditable" formControlName="items">
                </tui-multi-select>",
  "1. After": "
                <tui-textfield multi tuiChevron>
                <input tuiInputChip [readOnly]="!isEditable" formControlName="items" />
</tui-textfield>",
}
`;

exports[`ng-update legacy multi-select adds TODO comment when [search] is present: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select [search]="searchQuery" formControlName="items">
                    <tui-data-list-wrapper *tuiDataList [items]="items" />
                </tui-multi-select>",
  "1. After": "
                <tui-textfield multi tuiChevron>
                    <!-- TODO: (Taiga UI migration) [search] was removed. Use (input) on <input tuiInputChip (input)="onSearch($any($event).target.value)"> to track changes; no direct equivalent for programmatic writes. See: https://taiga-ui.dev/components/input-chip -->
<input tuiInputChip formControlName="items" />
<tui-data-list-wrapper *tuiDropdown [items]="items" />
                </tui-textfield>",
}
`;

