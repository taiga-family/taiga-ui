exports[`ng-update legacy multi-select keeps [stringify], [rows], [identityMatcher], [disabledItemHandler], tuiTextfieldSize on tui-textfield: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select
                    [stringify]="fn"
                    [rows]="3"
                    [identityMatcher]="matcher"
                    [disabledItemHandler]="handler"
                    tuiTextfieldSize="m"
                    formControlName="items"
                >
                </tui-multi-select>",
  "1. After": "
                <tui-textfield multi tuiChevron
                    [stringify]="fn"
                    [rows]="3"
                    [identityMatcher]="matcher"
                    [disabledItemHandler]="handler"
                    tuiTextfieldSize="m"
                >
                <input tuiInputChip formControlName="items" />
</tui-textfield>",
}
`;

exports[`ng-update legacy multi-select migrates (searchChange) to (input) on generated <input>: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select (searchChange)="onSearch($event)" formControlName="items">
                    <tui-data-list-wrapper *tuiDataList [items]="items" />
                </tui-multi-select>",
  "1. After": "
                <tui-textfield multi tuiChevron>
                    <!-- TODO: (Taiga UI migration) (searchChange) was replaced by (input) on <input tuiInputChip (input)="onSearch($any($event).target.value)">. See: https://taiga-ui.dev/components/input-chip -->
<input tuiInputChip formControlName="items" (input)="onSearch(($event.target as HTMLInputElement).value)" />
<tui-data-list-wrapper *tuiDropdown [items]="items" />
                </tui-textfield>",
}
`;

exports[`ng-update legacy multi-select migrates [tagValidator] to <tui-input-chip *tuiItem> with appearance binding: test.html 1`] = `
{
  "0. Before": "
                <tui-multi-select [tagValidator]="isValid" formControlName="items">
                    <tui-data-list-wrapper *tuiDataList [items]="items" />
                </tui-multi-select>",
  "1. After": "
                <tui-textfield multi tuiChevron>
                    <input tuiInputChip formControlName="items" />
<tui-input-chip *tuiItem="let ctx" [appearance]="isValid(ctx.item) ? '' : 'negative'" />
<tui-data-list-wrapper *tuiDropdown [items]="items" />
                </tui-textfield>",
}
`;

exports[`ng-update legacy multi-select migrates basic tui-multi-select with formControlName: test.html 1`] = `
