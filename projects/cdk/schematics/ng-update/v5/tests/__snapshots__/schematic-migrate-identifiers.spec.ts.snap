                @Component({
                    standalone: true,
                    template: '',
                })
                export class TestComponent {
                    public status: TuiStatus = 'error';
                }
            ",
}
`;

exports[`ng-update identifiers migration keeps tuiIsFlat usages in source code when migrating from @taiga-ui/kit: test.ts 1`] = `
