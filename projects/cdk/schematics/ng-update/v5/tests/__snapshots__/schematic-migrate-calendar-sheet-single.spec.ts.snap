exports[`ng-update calendar-sheet [single] → tuiCalendarSheetOptionsProvider handles multiple tui-calendar-sheet elements in one template: test.ts 1`] = `
{
  "0. Before": "
                import {Component} from '@angular/core';
                import {TuiCalendarSheet} from '@taiga-ui/core';

                @Component({
                    standalone: true,
                    imports: [TuiCalendarSheet],
                    templateUrl: './test.html',
                })
                export class TestComponent {}
            ",
  "1. After": "
                import {Component} from '@angular/core';
                import { TuiCalendarSheet, tuiCalendarSheetOptionsProvider } from '@taiga-ui/core';

                @Component({
                    standalone: true,
                    imports: [TuiCalendarSheet],
                    templateUrl: './test.html',
                    providers: [tuiCalendarSheetOptionsProvider({rangeMode: true})]
                })
                export class TestComponent {}
            ",
}
`;

