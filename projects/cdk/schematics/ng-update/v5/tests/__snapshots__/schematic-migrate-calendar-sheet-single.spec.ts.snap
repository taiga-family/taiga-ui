exports[`ng-update calendar-sheet [single] → tuiCalendarSheetOptionsProvider removes [single]="false" and adds rangeMode: true to existing tuiCalendarSheetOptionsProvider call: test.ts 1`] = `
{
  "0. Before": "
                import {Component} from '@angular/core';
                import {TuiCalendarSheet, tuiCalendarSheetOptionsProvider} from '@taiga-ui/core';

                @Component({
                    standalone: true,
                    imports: [TuiCalendarSheet],
                    templateUrl: './test.html',
                    providers: [tuiCalendarSheetOptionsProvider({someOption: 'x'})],
                })
                export class TestComponent {}
            ",
  "1. After": "
                import {Component} from '@angular/core';
                import {TuiCalendarSheet, tuiCalendarSheetOptionsProvider} from '@taiga-ui/core';

                @Component({
                    standalone: true,
                    imports: [TuiCalendarSheet],
                    templateUrl: './test.html',
                    providers: [tuiCalendarSheetOptionsProvider({someOption: 'x',
                        rangeMode: true
                    })],
                })
                export class TestComponent {}
            ",
}
`;

