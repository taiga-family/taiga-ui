                  ],
                  templateUrl: './test.html',
                  // ...
                })
                export class MyComponent {}
            ",
}
`;

exports[`ng-update moves [min] and [max] to <input tuiInputMonth>, [disabledItemHandler] to <tui-calendar-month *tuiDropdown>: test.html 1`] = `
{
  "0. Before": "
                <tui-input-month
                    formControlName="month"
                    [disabledItemHandler]="disabledHandler"
                    [max]="maxMonth"
                    [min]="minMonth"
                >
                    Month
                </tui-input-month>
            ",
  "1. After": "
                <tui-textfield
                    
                    
                    
                    
                >
<label tuiLabel>
                    Month
                </label>

<input tuiInputMonth formControlName="month" [max]="maxMonth" [min]="minMonth" />
<tui-calendar-month *tuiDropdown [disabledItemHandler]="disabledHandler" />
</tui-textfield>
            ",
}
`;

