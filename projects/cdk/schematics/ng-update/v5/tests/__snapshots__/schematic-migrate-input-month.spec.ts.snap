exports[`ng-update migrate TuiInputMonthModule to TuiInputMonth: test.html 1`] = `
{
  "0. Before": "
                <tui-input-month></tui-input-month>

                <tui-input-month [formControl]="control">Choose month</tui-input-month>

                <tui-input-month
                    formControlName="month"
                    [tuiTextfieldCleaner]="true"
                >
                    Select month
                    <input
                        placeholder="MM.YYYY"
                        tuiTextfieldLegacy
                    />
                </tui-input-month>

                <tui-input-month [(ngModel)]="value">Your month</tui-input-month>
            ",
  "1. After": "
                <tui-textfield>
<input tuiInputMonth />
<tui-calendar-month *tuiDropdown />
</tui-textfield>

                <tui-textfield >
<label tuiLabel>Choose month</label>

<input tuiInputMonth [formControl]="control" />
<tui-calendar-month *tuiDropdown />
</tui-textfield>

                <tui-textfield
                    
                    [tuiTextfieldCleaner]="true"
                >
<label tuiLabel>
                    Select month
                    </label>
<input
                        placeholder="MM.YYYY"
                        tuiInputMonth formControlName="month"
                    />
                
<tui-calendar-month *tuiDropdown />
</tui-textfield>

                <tui-textfield >
<label tuiLabel>Your month</label>

<input tuiInputMonth [(ngModel)]="value" />
<tui-calendar-month *tuiDropdown />
</tui-textfield>
            ",
}
`;

exports[`ng-update migrate TuiInputMonthModule to TuiInputMonth: test.ts 1`] = `
{
