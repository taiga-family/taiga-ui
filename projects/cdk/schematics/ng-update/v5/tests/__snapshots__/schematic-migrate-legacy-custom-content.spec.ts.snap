exports[`ng-update legacy tuiTextfieldCustomContent across controls imports are registered adds TuiIcon and PolymorpheusOutlet imports for tui-select binding: test.ts 1`] = `
{
  "0. Before": "
                    import {TuiSelectModule} from '@taiga-ui/legacy';

                    @Component({
                      standalone: true,
                      imports: [TuiSelectModule],
                      templateUrl: './test.html',
                    })
                    export class TestComponent {}
                ",
  "1. After": "import { PolymorpheusOutlet } from "@taiga-ui/polymorpheus";
