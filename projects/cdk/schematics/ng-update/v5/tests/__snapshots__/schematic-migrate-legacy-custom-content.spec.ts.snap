import { TuiSelect } from "@taiga-ui/kit";

                                        @Component({
                      standalone: true,
                      imports: [TuiSelect, TuiIcon, PolymorpheusOutlet],
                      templateUrl: './test.html',
                    })
                    export class TestComponent {}
                ",
}
`;

