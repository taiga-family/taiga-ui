exports[`ng-update readOnly on legacy controls different legacy controls moves [readOnly] on tui-select to <input tuiSelect>: test.html 1`] = `
{
  "0. Before": "
                    <tui-select
                        [readOnly]="!show"
                        [(ngModel)]="value"
                    >
                        Select user
                        <tui-data-list-wrapper
                            *tuiDataList
                            [items]="items"
                        />
                    </tui-select>
                ",
  "1. After": "
                    <!-- TODO: (Taiga UI migration) tui-select was partially migrated. Complete migration manually. See examples: https://taiga-ui.dev/components/select -->
<tui-textfield tuiChevron
                    >
<label tuiLabel>
                        Select user
                        </label>

<input tuiSelect [(ngModel)]="value" [readOnly]="!show" />
<tui-data-list-wrapper
                            *tuiDropdown
                            [items]="items"
                        />
                    </tui-textfield>
                ",
}
`;

