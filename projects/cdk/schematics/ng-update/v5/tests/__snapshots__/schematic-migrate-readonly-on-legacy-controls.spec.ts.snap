exports[`ng-update readOnly on legacy controls inline template moves [readOnly] inside an inline template: test.ts 1`] = `
{
  "0. Before": "
                    import {ChangeDetectionStrategy, Component} from '@angular/core';
                    import {FormsModule} from '@angular/forms';
                    import {TuiInputModule} from '@taiga-ui/legacy';

                    @Component({
                        selector: 'inline-example',
                        imports: [FormsModule, TuiInputModule],
                        template: \`
                            <tui-input
                                [readOnly]="!show"
                                [(ngModel)]="value"
                            >
                                Name on the card
                            </tui-input>
                        \`,
                        changeDetection: ChangeDetectionStrategy.OnPush,
                    })
                    export class InlineExample {
                        show = true;
                        value = '';
                    }
                ",
  "1. After": "import { TuiInput } from "@taiga-ui/core";

                    import {ChangeDetectionStrategy, Component} from '@angular/core';
                    import {FormsModule} from '@angular/forms';

                    @Component({
                        selector: 'inline-example',
                        imports: [FormsModule, TuiInput],
                        template: \`
                            <tui-textfield>
                            <label tuiLabel>Name on the card</label>
                            <input tuiInput [(ngModel)]="value" [readOnly]="!show" />
                            </tui-textfield>
                        \`,
                        changeDetection: ChangeDetectionStrategy.OnPush,
                    })
                    export class InlineExample {
                        show = true;
                        value = '';
                    }
                ",
}
`;

exports[`ng-update readOnly on legacy controls multiple occurrences migrates [readOnly] on multiple legacy controls in one template: test.html 1`] = `
{
  "0. Before": "
                    <tui-input [readOnly]="!show">First</tui-input>
                    <tui-textarea [readOnly]="!show">Second</tui-textarea>
                    <tui-select
                        [readOnly]="!show"
                        [(ngModel)]="value"
                    >
                        Third
                        <tui-data-list-wrapper
                            *tuiDataList
                            [items]="items"
                        />
                    </tui-select>
                ",
  "1. After": "
                    <tui-textfield>
                    <label tuiLabel>First</label>
                    <input tuiInput [readOnly]="!show" />
                    </tui-textfield>
                    <!-- TODO: (Taiga UI migration) tui-textarea migration (see https://taiga-ui.dev/components/textarea):
     - Legacy tui-textarea had a fixed height of 20 rows by default. New component auto-resizes between [min] (default: 1) and [max] (default: 3) rows. Set min and max explicitly if the previous layout needs to be preserved.
-->
                    <tui-textfield>
                    <label tuiLabel>Second</label>
                    <textarea tuiTextarea [readOnly]="!show"></textarea>
                    </tui-textfield>
                    <!-- TODO: (Taiga UI migration) tui-select was partially migrated. Complete migration manually. See examples: https://taiga-ui.dev/components/select -->
<tui-textfield tuiChevron
                    >
<label tuiLabel>
                        Third
                        </label>

<input tuiSelect [(ngModel)]="value" [readOnly]="!show" />
<tui-data-list-wrapper
                            *tuiDropdown
                            [items]="items"
                        />
                    </tui-textfield>
                ",
}
`;

