exports[`ng-update legacy textarea keeps tuiTextfieldCleaner and tuiHintContent on tui-textfield wrapper: test.html 1`] = `
{
  "0. Before": "
                <tui-textarea
                    formControlName="value"
                    [tuiTextfieldCleaner]="true"
                    tuiHintContent="Hint text"
                    tuiHintDirection="bottom-right"
                >
                    Label
                </tui-textarea>",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tui-textarea migration (see https://taiga-ui.dev/components/textarea):
     - Text content "Label" became placeholder on <textarea>. Add <label tuiLabel>Label</label> inside <tui-textfield> if a floating label is needed.
-->
<tui-textfield [tuiTextfieldCleaner]="true" tuiHintContent="Hint text" tuiHintDirection="bottom-right">
<textarea placeholder="Label" tuiTextarea formControlName="value"></textarea>
</tui-textfield>",
}
`;

