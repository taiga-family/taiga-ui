exports[`ng-update adds TODO for [editable] and [autoColor], silently removes [inputHidden] and [removable]: test.html 1`] = `
{
  "0. Before": "
                <tui-input-tag
                    formControlName="tags"
                    [autoColor]="true"
                    [editable]="false"
                    [inputHidden]="true"
                    [removable]="false"
                >
                    Tags
                </tui-input-tag>
            ",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tui-input-tag migration (see https://taiga-ui.dev/components/input-chip):
     - [autocolor]: use tuiChip with auto-color appearance instead. See https://taiga-ui.dev/components/chip#auto-color
     - [editable]: move to <tui-input-chip *tuiItem="let ctx" [editable]="..."> inside <tui-textfield multi>. See https://taiga-ui.dev/components/input-chip. -->
<tui-textfield
                    
                    
                    
                    
                    
                 multi>
<label tuiLabel>
                    Tags
                </label>

<input tuiInputChip formControlName="tags" />
</tui-textfield>
            ",
}
`;

exports[`ng-update adds TODO for [tagValidator] and [search]: test.html 1`] = `
{
  "0. Before": "
                <tui-input-tag
                    formControlName="tags"
                    [tagValidator]="myValidator"
                    [(search)]="searchValue"
                >
                    Tags
                </tui-input-tag>
            ",
  "1. After": "
                <!-- TODO: (Taiga UI migration) tui-input-tag migration (see https://taiga-ui.dev/components/input-chip):
     - [tagvalidator]: use <tui-input-chip *tuiItem="let ctx" [appearance]="myValidator(ctx.item) ? '' : 'negative'"> inside <tui-textfield multi>. See https://taiga-ui.dev/components/input-chip#customization
     - [(search)]: use (input) on <input tuiInputChip (input)="onSearch($any($event).target.value)"> to track changes; no direct equivalent for programmatic writes. -->
<tui-textfield
                    
                    
                    
                 multi>
<label tuiLabel>
                    Tags
                </label>

<input tuiInputChip formControlName="tags" />
</tui-textfield>
            ",
}
`;

exports[`ng-update migrate TuiInputTagModule to TuiInputChip: test.html 1`] = `
{
  "0. Before": "
                <tui-input-tag></tui-input-tag>

                <tui-input-tag
                    [formControl]="control"
                    [tuiTextfieldCleaner]="true"
                >
                    Enter tags
                </tui-input-tag>

