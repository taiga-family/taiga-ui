{
    "extends": "../../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "composite": false,
        "declaration": true,
        "incremental": false,
        "module": "commonjs",
        "outDir": "../../../dist/cdk",
        "target": "es6",
        "tsBuildInfoFile": null,
        "types": ["node"],
        "verbatimModuleSyntax": false
    },
    "include": [
        "../constants/version.ts",
        "./**/*",
        "./**/collection.json",
        "./**/migration.json",
        "./**/schema.json"
    ],
    "exclude": ["./**/*.spec.ts"]
}
