{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "cdk",
    "implicitDependencies": [
        "!testing",
        "!core",
        "!styles"
    ],
    "prefix": "tui",
    "projectType": "library",
    "sourceRoot": "projects/{projectName}",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "commands": ["nx prebuild {projectName}", "nx postbuild {projectName}"],
                "parallel": false
            },
            "outputs": ["{workspaceRoot}/dist/cdk"]
        },
        "postbuild": {
            "executor": "nx:run-commands",
            "options": {
                "command": "tsc -p ./{projectRoot}/schematics/tsconfig.schematics.json"
            }
        },
        "prebuild": {
            "dependsOn": [
                {
                    "dependencies": true,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "@angular/build:ng-packagr",
            "options": {
                "project": "{projectRoot}/ng-package.json",
                "tsConfig": "tsconfig.build.json"
            }
        },
        "publish": {
            "dependsOn": [
                {
                    "dependencies": false,
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "commands": ["cp ./LICENSE ./dist/{projectName}", "ts-node ./scripts/publish.ts --path ./dist/{projectName} --dry-run {args.dry-run} --customVersion {args.customVersion} --customTag {args.customTag}"],
                "forwardAllArgs": false,
                "parallel": false
            }
        },
        "schematics": {
            "dependsOn": [
                {
                    "params": "ignore",
                    "target": "build"
                }
            ],
            "executor": "nx:run-commands",
            "options": {
                "command": "schematics ./dist/{projectName}:updateToV{args.v} --allow-private --dry-run true"
            }
        },
        "test": {
            "dependsOn": [
                {
                    "params": "ignore",
                    "target": "postbuild"
                }
            ],
            "executor": "@nx/jest:jest",
            "options": {
                "collectCoverageFrom": ["<rootDir>/{projectRoot}/**/*.ts"],
                "coverageDirectory": "coverage/{projectName}",
                "jestConfig": "package.json",
                "testMatch": ["<rootDir>/{projectRoot}/**/*.spec.ts"]
            },
            "outputs": ["{workspaceRoot}/coverage/{projectName}"]
        }
    }
}
